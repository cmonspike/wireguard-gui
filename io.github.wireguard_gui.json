{
  "id": "io.github.wireguard_gui",
  "runtime": "org.gnome.Platform",
  "runtime-version": "47",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],
  "command": "wireguard-gui",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "build-args": [
      "--share=network"
    ],
    "env": {
      "CARGO_HOME": "/run/build/wireguard-gui/cargo"
    }
  },
  "modules": [
    {
      "name": "wireguard-gui",
      "buildsystem": "simple",
      "build-commands": [
        "cargo build --release --manifest-path Cargo.toml",
        "install -Dm755 target/release/wireguard-gui -t /app/bin/",
        "install -Dm755 target/release/wireguard-gui-helper -t /app/bin/",
        "install -Dm644 data/io.github.wireguard_gui.desktop -t /app/share/applications/",
        "install -Dm644 data/io.github.wireguard_gui.metainfo.xml -t /app/share/metainfo/",
        "install -Dm644 data/icons/hicolor/scalable/apps/io.github.wireguard_gui.svg -t /app/share/icons/hicolor/scalable/apps/"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
